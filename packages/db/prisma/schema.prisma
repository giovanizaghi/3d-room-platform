generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RenderStatus {
  queued
  processing
  done
  failed
  stalled
}

model Model3D {
  id            String   @id @default(uuid())
  name          String
  description   String?
  blendFilePath String
  thumbnailPath String?
  gltfFilePath          String?
  gltfConversionError   String?
  createdAt             DateTime @default(now())

  renders Render[]
}

model Render {
  id        String       @id @default(uuid())
  status    RenderStatus @default(queued)
  items     Json?
  imageUrl  String?
  aiEnhance Boolean      @default(false)

  // Timestamps
  createdAt       DateTime  @default(now())
  queuedAt        DateTime  @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  lastHeartbeatAt DateTime?

  // Progress & Logs
  progress      Int     @default(0)
  progressLabel String?
  lastLogLine   String?

  // Failure
  errorMessage String?
  attempts     Int     @default(0)

  // Retry lineage
  retriedFromId String?
  retriedFrom   Render?  @relation("RenderRetry", fields: [retriedFromId], references: [id])
  retriedBy     Render[] @relation("RenderRetry")

  // Relations
  modelId String
  model   Model3D @relation(fields: [modelId], references: [id])

  @@index([modelId, status])
  @@index([status, lastHeartbeatAt])
  @@index([createdAt])
  @@index([retriedFromId])
}
