generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RenderStatus {
  pending
  processing
  done
}

model Model3D {
  id            String   @id @default(uuid())
  name          String
  description   String?
  blendFilePath String
  thumbnailPath String?
  createdAt     DateTime @default(now())

  renders Render[]
}

model Render {
  id        String       @id @default(uuid())
  status    RenderStatus @default(pending)
  items     Json?
  imageUrl  String?
  createdAt DateTime     @default(now())

  modelId String
  model   Model3D @relation(fields: [modelId], references: [id])
}
