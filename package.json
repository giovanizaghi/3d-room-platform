{
  "name": "3d-room-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "dev:web": "pnpm --filter @apps/web dev",
    "dev:api": "pnpm --filter @apps/api dev",
    "dev:worker": "pnpm --filter @apps/worker dev",
    "db:migrate": "pnpm --filter @repo/db db:migrate",
    "db:deploy": "pnpm --filter @repo/db db:deploy",
    "db:studio": "pnpm --filter @repo/db db:studio",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down -v",
    "test:unit": "pnpm -r --filter='!@tests/e2e' run test",
    "test": "pnpm test:unit"
  },
  "devDependencies": {
    "@types/node": "^22.8.7",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6"
  }
}
