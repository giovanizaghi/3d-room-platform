DATABASE_URL="postgresql://postgres:postgres@localhost:5432/room_platform?schema=public"
REDIS_URL="redis://localhost:6379"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# OpenAI AI Enhancement (optional — leave OPENAI_API_KEY empty to disable)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_IMAGE_MODEL=gpt-image-1
ENABLE_AI_RENDER_IMPROVEMENT=false

# Object storage — required on Railway (volumes are per-service and can't be shared).
# Supports AWS S3 and any S3-compatible provider (Cloudflare R2, MinIO, etc.).
# Leave blank to use local filesystem (only works for single-machine / docker-compose).
STORAGE_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=your_r2_access_key_id
STORAGE_SECRET_ACCESS_KEY=your_r2_secret_access_key
STORAGE_BUCKET=3d-room-platform
STORAGE_PUBLIC_URL=https://pub-<hash>.r2.dev
STORAGE_REGION=auto
